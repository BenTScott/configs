#!/bin/bash
# Lists open CRs for a user, formatted for Slack
USER="${1:-$(whoami)}"
COOKIE=~/.midway/cookie

OUTPUT=$(/usr/bin/curl -s "https://code.amazon.com/reviews/from-user/${USER}?open=true" \
  -L --cookie "$COOKIE" --cookie-jar "$COOKIE" \
  -H "X-Requested-With: XMLHttpRequest" \
  -H "Accept: application/json, text/javascript, */*" \
| python3 -c "
import json, sys, re
data = json.load(sys.stdin)
html = data.get('html', '')
rows = re.findall(r\"<tr class=.open.>(.*?)</tr>\", html, re.DOTALL)
for row in rows:
    cr = re.search(r'/reviews/(CR-\d+)', row)
    title = re.search(r\"class=.black.><a [^>]+>([^<]+)</a>\", row)
    if cr and title:
        approver_match = re.search(r'fa-thumbs-o-up[^>]*></i>\s*(.+)', row)
        line = f'• {title.group(1)} — https://code.amazon.com/reviews/{cr.group(1)}'
        if approver_match:
            approvers = [a.strip() for a in approver_match.group(1).split(',') if a.strip()]
            line += ' :ship: ' + ', '.join(approvers)
        print(line)
if not rows:
    print('No open CRs found.')
")

echo "$OUTPUT"
if echo "$OUTPUT" | grep -q '^•'; then
  encoded=$(echo -n "$OUTPUT" | base64 -w 0)
  if [ -n "$TMUX" ]; then
    printf '\033Ptmux;\033\033]52;c;%s\a\033\\' "$encoded"
  else
    printf '\033]52;c;%s\a' "$encoded"
  fi
  echo "✓ Copied to clipboard" >&2
fi
